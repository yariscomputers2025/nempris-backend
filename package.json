{
  "name": "nempris-backend",
  "version": "1.0.0",
  "description": "Scalable Node.js + Express e-commerce backend with MongoDB, JWT auth, and Cloudinary image uploads.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
     "make-admin": "node makeAdmin.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.38.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.32.5",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "ecommerce",
    "express",
    "mongodb",
    "jwt",
    "cloudinary"
  ],
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["<rootDir>/tests/jest.setup.js"],
    "testMatch": ["**/tests/**/*.test.js"],
    "verbose": true
  },
  "license": "MIT"
}
